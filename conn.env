# MySQL (OPZIONALE)
  mysql:
    image: mysql:8.0
    container_name: mysql-db
    environment:
      - MYSQL_ROOT_PASSWORD=root
      - MYSQL_DATABASE=appdb
      - MYSQL_USER=app
      - MYSQL_PASSWORD=app
      - TZ=Europe/Rome
    ports:
      - "3306:3306"
    volumes:
      - mysql_data:/var/lib/mysql
    restart: unless-stopped

  # phpMyAdmin (OPZIONALE) per gestire MySQL via browser
  phpmyadmin:
    image: phpmyadmin:5
    container_name: pma
    environment:
      - PMA_HOST=mysql
      - PMA_USER=root
      - PMA_PASSWORD=root
      - TZ=Europe/Rome
    ports:
      - "8082:80"                  # http://localhost:8082
    depends_on:
      - mysql
    restart: unless-stopped

  # MongoDB (OPZIONALE)
  mongo:
    image: mongo:6
    container_name: mongo-db
    ports:
      - "27017:27017"
    volumes:
      - mongo_data:/data/db
    environment:
      - TZ=Europe/Rome
    restart: unless-stopped

  # Mongo Express (OPZIONALE) per gestire MongoDB via browser
  mongo-express:
    image: mongo-express:1.0.2-20
    container_name: mongo-express
    environment:
      - ME_CONFIG_MONGODB_SERVER=mongo
      - ME_CONFIG_MONGODB_ENABLE_ADMIN=true
      - ME_CONFIG_BASICAUTH_USERNAME=admin
      - ME_CONFIG_BASICAUTH_PASSWORD=admin
      - TZ=Europe/Rome
    ports:
      - "8084:8081"                # http://localhost:8084
    depends_on:
      - mongo
    restart: unless-stopped

volumes:
  mysql_data:
  mongo_data:
