TZ=Europe/Rome

# Porte (puoi cambiarle qui)

WEB_PORT=8090
DEVTOOLS_PORT=9290
PHP_PORT=8084
PMA_PORT=8083
MONGO_EXPRESS_PORT=8085
MYSQL_HOST_PORT=3309       # usa 3309 per evitare conflitti con MySQL locale
MONGO_HOST_PORT=27018       # usa 27018 per evitare conflitti con Mongo locale

# MySQL
MYSQL_ROOT_PASSWORD=changemeRoot!
MYSQL_DATABASE=appdb
MYSQL_USER=app
MYSQL_PASSWORD=changemeApp!

# Mongo (se abiliti auth)
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=changemeAdmin!
