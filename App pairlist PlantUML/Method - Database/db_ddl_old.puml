== MySQL — Migrations (Laravel-style DDL)
{{{
-- users
CREATE TABLE users (
  id BIGINT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
  email VARCHAR(255) UNIQUE,
  pwd_hash VARCHAR(255),
  name VARCHAR(120),
  plan ENUM('free','pro','family','business') DEFAULT 'free',
  twofa_secret VARCHAR(64) NULL,
  created_at DATETIME, updated_at DATETIME
);

-- pairs
CREATE TABLE pairs (
  id BIGINT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
  owner_id BIGINT UNSIGNED NOT NULL,
  name VARCHAR(120),
  created_at DATETIME, updated_at DATETIME,
  INDEX idx_pairs_owner_start (owner_id)
);

-- pair_members
CREATE TABLE pair_members (
  pair_id BIGINT UNSIGNED NOT NULL,
  user_id BIGINT UNSIGNED NOT NULL,
  role ENUM('owner','member') NOT NULL,
  joined_at DATETIME NOT NULL,
  PRIMARY KEY (pair_id, user_id)
);

-- lists
CREATE TABLE lists (
  id BIGINT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
  pair_id BIGINT UNSIGNED NOT NULL,
  name VARCHAR(120),
  is_archived TINYINT(1) DEFAULT 0,
  created_at DATETIME, updated_at DATETIME,
  INDEX idx_lists_arch (is_archived)
);

-- sections
CREATE TABLE sections (
  id BIGINT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
  list_id BIGINT UNSIGNED NOT NULL,
  name VARCHAR(64),
  icon VARCHAR(32) NULL,
  color VARCHAR(16) NULL,
  position INT NOT NULL,
  is_default TINYINT(1) DEFAULT 0,
  created_at DATETIME, updated_at DATETIME,
  INDEX idx_sections_pos (list_id, position)
);

-- list_items
CREATE TABLE list_items (
  id BIGINT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
  list_id BIGINT UNSIGNED NOT NULL,
  section_id BIGINT UNSIGNED NULL,
  title VARCHAR(255) NOT NULL,
  notes TEXT NULL,
  qty DECIMAL(10,2) NULL,
  unit VARCHAR(16) NULL,
  dept VARCHAR(32) NULL,
  is_pantry TINYINT(1) DEFAULT 0,
  assigned_to BIGINT UNSIGNED NULL,
  is_done TINYINT(1) DEFAULT 0,
  position INT DEFAULT 0,
  due_at DATETIME NULL,
  mongo_ref CHAR(24) NULL,
  created_at DATETIME, updated_at DATETIME,
  FULLTEXT(title, notes),
  INDEX idx_items_done (is_done),
  INDEX idx_items_order (list_id, section_id, position)
);

-- events
CREATE TABLE events (
  id BIGINT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
  owner_id BIGINT UNSIGNED NOT NULL,
  title VARCHAR(255) NOT NULL,
  start_at DATETIME NOT NULL,
  end_at DATETIME NOT NULL,
  location VARCHAR(255),
  lat DECIMAL(9,6) NULL,
  lng DECIMAL(9,6) NULL,
  notes TEXT NULL,
  ics_hash CHAR(32) NULL,
  public_hash CHAR(12) UNIQUE,
  mongo_ref CHAR(24) NULL,
  created_at DATETIME, updated_at DATETIME,
  INDEX idx_events_owner_start (owner_id, start_at)
);

-- event_guests
CREATE TABLE event_guests (
  event_id BIGINT UNSIGNED NOT NULL,
  guest VARCHAR(255) NOT NULL,
  status ENUM('invited','accepted','declined') DEFAULT 'invited',
  PRIMARY KEY (event_id, guest)
);

-- assets
CREATE TABLE assets (
  id BIGINT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
  owner_id BIGINT UNSIGNED NOT NULL,
  name VARCHAR(255) NOT NULL,
  category VARCHAR(64) NULL,
  brand VARCHAR(64) NULL,
  model VARCHAR(64) NULL,
  serial VARCHAR(64) NULL,
  purchase_date DATE NULL,
  price DECIMAL(10,2) NULL,
  notes TEXT NULL,
  mongo_ref CHAR(24) NULL,
  created_at DATETIME, updated_at DATETIME
);

-- receipts
CREATE TABLE receipts (
  id BIGINT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
  item_id BIGINT UNSIGNED NOT NULL,
  file_url VARCHAR(255) NOT NULL,
  vendor VARCHAR(128) NULL,
  doc_date DATE NULL,
  doc_number VARCHAR(64) NULL,
  tax_id VARCHAR(32) NULL,
  mongo_ref CHAR(24) NULL,
  created_at DATETIME
);

-- warranties
CREATE TABLE warranties (
  id BIGINT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
  item_id BIGINT UNSIGNED NOT NULL,
  start_date DATE NOT NULL,
  end_date DATE NOT NULL,
  terms TEXT NULL,
  vendor_contact VARCHAR(255) NULL
);

-- reminders
CREATE TABLE reminders (
  id BIGINT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
  related_type ENUM('warranty','event','list_item') NOT NULL,
  related_id BIGINT UNSIGNED NOT NULL,
  due_at DATETIME NOT NULL,
  status ENUM('pending','sent','dismissed') DEFAULT 'pending'
);

-- loyalty_cards
CREATE TABLE loyalty_cards (
  id BIGINT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
  owner_id BIGINT UNSIGNED NOT NULL,
  store_name VARCHAR(128) NOT NULL,
  barcode_format ENUM('EAN13','CODE128','QR','PDF417','EAN8','CODE39') NOT NULL,
  code_value VARCHAR(64) NOT NULL,
  color VARCHAR(16) NULL,
  notes VARCHAR(255) NULL,
  created_at DATETIME
);

-- stores (optional)
CREATE TABLE stores (
  id BIGINT UNSIGNED AUTO_INCREMENT PRIMARY KEY,
  name VARCHAR(128) NOT NULL,
  brand VARCHAR(64) NULL,
  address VARCHAR(255) NULL,
  lat DECIMAL(9,6) NULL,
  lng DECIMAL(9,6) NULL,
  created_at DATETIME
);
}}}
endlegend

