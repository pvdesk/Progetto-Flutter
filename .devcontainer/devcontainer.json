{
    "name": "Progetto-Flutter",
    "dockerComposeFile": "../docker-compose.yml",
    "service": "flutter",
    "runServices": [
        "db",
        "phpmyadmin",
        "mongo",
        "mongo-express"
    ],
    "workspaceFolder": "/workspace",
    "overrideCommand": false,
    "shutdownAction": "none",
    "customizations": {
        "vscode": {
            "extensions": [
                "Dart-Code.dart-code",
                "Dart-Code.flutter"
            ]
        }
    }
}